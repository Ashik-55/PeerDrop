                  <div class="profile-info">
                      <span class="label">Your Identity</span>
                      <h2 id="myName">Connecting...</h2>
                  </div>
              </div>

              <nav class="sidebar-nav">
                  <div class="nav-item active"><span>🌐</span> Network</div>
                  <div class="nav-item" id="themeToggle"><span>🌙</span> Dark Mode</div>
              </nav>
          </aside>

          <main class="main-stage">
              <header class="stage-header">
                  <div class="status-chip">
                      <span class="pulse-dot"></span>
                      <span id="userCount">0 Peers Online</span>
                  </div>
              </header>


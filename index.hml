  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>PeerDrop | Secure P2P</title>
      <link rel="stylesheet" href="style.css">
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
  </head>
  <body>
      <div class="app-container">
          <aside class="sidebar">
              <div class="brand">
                  <div class="logo-icon">⚡</div>
                  <h1>PeerDrop</h1>
              </div>
              
              <div class="my-profile">
                  <div class="avatar-circle" id="myAvatar"></div>
                  <div class="profile-info">
                      <span class="label">Your Identity</span>
                      <h2 id="myName">Connecting...</h2>
                  </div>
              </div>


              <div class="download-history">
                  <span class="label">Download History</span>
                  <ul id="historyList"></ul>
              </div>
          </aside>

          <main class="main-stage">
              <header class="stage-header">
                  <div class="status-chip">
                      <span class="pulse-dot"></span>
                      <span id="userCount">0 Peers Online</span>
                  </div>
              </header>

              <div class="users-grid" id="usersGrid">
                  </div>
          </main>
      </div>

      <div id="requestModal" class="modal hidden">
          <div class="glass-card modal-content">
              <div class="modal-icon">📩</div>
              <h3>Incoming Stream</h3>
              <p id="requestText"></p>
              <div class="modal-btns">
                  <button id="acceptBtn" class="btn-primary">Accept</button>
                  <button id="rejectBtn" class="btn-ghost">Decline</button>
              </div>
          </div>
      </div>

      <div id="transferModal" class="modal hidden">
          <div class="glass-card modal-content">
              <h3 id="fileName">Transferring...</h3>
              <div class="progress-wrapper">
                  <div class="progress-bar">
                      <div id="progressFill"></div>
                  </div>
                  <div class="progress-details">
                      <span id="progressText">0%</span>
                      <span id="transferSpeed">Streaming...</span>
                  </div>
              </div>
          </div>
      </div>

      <input type="file" id="fileInput" hidden>
      <script src="app.js"></script>
  </body>
  </html>
  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>PeerDrop | Secure P2P</title>
      <link rel="stylesheet" href="style.css">
      <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
  </head>
  <body>
      <div class="app-container">
          <aside class="sidebar">
